SENTINEL_DB_URL=sqlite+pysqlite:///./data/sentinel.db
NVD_API_KEY=
GITHUB_TOKEN=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Use the regional inference-profile prefix where on-demand isn't allowed:
#   ap-south-1 (Mumbai)  -> apac.anthropic.claude-3-5-sonnet-20241022-v2:0
#   eu-* regions         -> eu.anthropic.claude-3-5-sonnet-20241022-v2:0
#   us-* regions         -> us.anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
SENTINEL_LOG_LEVEL=INFO
